# --- Claude Code ---
# Ignore only machine-local, personal settings. launch.json is shared.
.claude/settings.local.json

# --- BMAD generated skills ---
# Generated from _bmad/ (version pinned in _bmad/_config/manifest.yaml), so they are
# rebuilt rather than committed. Each developer runs the installer once for their tool:
#   npx bmad-method install --modules bmm --tools claude-code   (Claude Code)
#   npx bmad-method install --modules bmm --tools codex         (Codex)
.claude/skills/
.agents/skills/

# Per-developer BMAD install answers (user_name, skill level).
# BMAD's own convention is that *.user.toml is personal, but it only
# auto-ignores the copy under _bmad/custom/.
_bmad/**/*.user.toml

# --- Maven / Java build output ---
target/
!.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war

# --- Angular / Node ---
node_modules/
dist/
.angular/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*

# --- IDE ---
.idea/
*.iml
*.iws
.vscode/
.settings/
.project
.classpath
nbproject/private/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs & runtime ---
*.log
logs/

# --- Local environment / secrets ---
.env
.env.local
*.local.properties
application-local.yml
