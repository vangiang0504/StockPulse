{
  "info": {
    "name": "Product API",
    "description": "StockPulse Product API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_JWT_TOKEN",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "List Products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/products?page=0&size=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "products"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" }
          ]
        }
      }
    },
    {
      "name": "Get Product Details",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "products", "{{productId}}"]
        }
      }
    },
    {
      "name": "Search Products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/search?q=IPH",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "products", "search"],
          "query": [
            { "key": "q", "value": "IPH" }
          ]
        }
      }
    },
    {
      "name": "Create Product",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sku\": \"APP-IPH-15\",\n  \"name\": \"iPhone 15 Pro\",\n  \"description\": \"Apple Smartphone\",\n  \"categoryId\": 1,\n  \"unit\": \"PCS\",\n  \"minStock\": 10,\n  \"maxStock\": 500,\n  \"reorderPoint\": 50,\n  \"reorderQuantity\": 100\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/products",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "products"]
        }
      }
    },
    {
      "name": "Update Product",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"iPhone 15 Pro Max\",\n  \"minStock\": 20\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "products", "{{productId}}"]
        }
      }
    }
  ]
}
